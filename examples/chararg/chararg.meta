[ccpp-table-properties]
  name = chararg
  type = scheme

[ccpp-arg-table]
  name = chararg_run
  type = scheme
[ ncol ]
  standard_name = horizontal_loop_extent
  long_name = number of columns in this chunk
  units = count
  dimensions = ()
  type = integer
  intent = in
[ nz ]
  standard_name = vertical_layer_dimension
  long_name = number of vertical layers
  units = count
  dimensions = ()
  type = integer
  intent = in
[ temp ]
  standard_name = air_temperature
  long_name = air temperature
  units = K
  dimensions = (horizontal_dimension, vertical_layer_dimension)
  type = real | kind = kind_phys
  intent = inout
[ label ]
  standard_name = chararg_run_label
  long_name = run label for chararg scheme
  units = none
  dimensions = ()
  type = character
  kind = len=32
  intent = in
[ errmsg ]
  standard_name = ccpp_error_message
  long_name = error message for error handling in CCPP
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = out
[ errflg ]
  standard_name = ccpp_error_code
  long_name = error code for error handling in CCPP
  units = 1
  dimensions = ()
  type = integer
  intent = out
